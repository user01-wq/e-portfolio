# ─────────────────────────────────────────────────────────
#  Copy this file to  .env.local  แล้วใส่ค่าจริงของคุณ
#  cp .env.example .env.local
# ─────────────────────────────────────────────────────────

# ── Supabase Cloud (https://supabase.com) ─────────────────
#  ไปที่  Project Settings → API
#  แล้วคัดลอก Project URL และ anon public key มาวาง
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase Local (npx supabase start) ───────────────────
#  ใช้ค่านี้เมื่อรันบน localhost ด้วย Supabase CLI
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
